<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:RetroAchievCollection.ViewModels"
             xmlns:components="clr-namespace:RetroAchievCollection.Views.Cards"
             mc:Ignorable="d"
             x:Class="RetroAchievCollection.Views.GameView"
             x:DataType="vm:GameViewModel"
             x:CompileBindings="True">

    <Grid RowDefinitions="1, Auto, *">
        <Separator Grid.Row="0" Margin="10 0" />

        <Grid Grid.Row="1"
              ColumnDefinitions="*, Auto, *"
              Margin="10 6">
            
            <!-- SEE CONSOLES BUTTON -->
            <Border Grid.Column="0"
                    Classes="border-button"
                    HorizontalAlignment="Left"
                    Margin="0">
                <Button ToolTip.Tip="Show Consoles"
                        Classes="base-button"
                        Command="{Binding LoadConsolesView}">
                    <PathIcon Data="{StaticResource left_arrow}" Foreground="White" />
                </Button>
            </Border>

            <!-- CONSOLE NAME -->
            <Border Grid.Column="1" VerticalAlignment="Center">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock Text="{Binding ConsoleName}"
                               FontSize="16"
                               FontWeight="Bold" />
                </StackPanel>
            </Border>

            <Grid Grid.Column="2"
                  HorizontalAlignment="Right"
                  ColumnDefinitions="*, Auto, Auto">
                <Grid.Styles>
                    <Style Selector="StackPanel">
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>

                    <Style Selector="TextBox">
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Setter Property="Height" Value="40" />
                        <Setter Property="AcceptsReturn" Value="False" />
                        <Setter Property="TextWrapping" Value="NoWrap" />
                        <Setter Property="SelectionBrush" Value="LightGray" />
                        <Setter Property="SelectionForegroundBrush" Value="Black" />
                    </Style>
                </Grid.Styles>

                <!-- SEARCH BAR -->
                <StackPanel Grid.Column="0"
                            Width="400">
                    <TextBox Watermark="Search..." Text="{Binding SearchTextGames}">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding SearchGames}" />
                        </TextBox.KeyBindings>
                    </TextBox>
                </StackPanel>

                <!-- SEARCH BUTTON -->
                <Border Grid.Column="1" Classes="border-button">
                    <Button ToolTip.Tip="Search"
                            Classes="base-button"
                            Command="{Binding SearchGames}">
                        <PathIcon Data="{StaticResource search}" Foreground="White" />
                    </Button>
                </Border>

                <!-- SYNCHRONIZE BUTTON -->
                <Border Grid.Column="2" Classes="border-button">
                    <Button ToolTip.Tip="Synchronize all games"
                            Classes="base-button"
                            Command="{Binding SynchronizeConsoleGames}">
                        <PathIcon Data="{StaticResource arrow_sync_regular}" Foreground="White" />
                    </Button>
                </Border>
            </Grid>
        </Grid>

        <!-- GAME CARDS -->
        <ScrollViewer Grid.Row="2">
            <ItemsControl ItemsSource="{Binding Games}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <components:GameCard DataContext="{Binding}" Margin="0 5" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>